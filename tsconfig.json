{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@forgeai/shared/*": ["packages/shared/src/*"],
      "@forgeai/config/*": ["packages/config/src/*"],
      "@forgeai/db/*": ["packages/db/src/*"],
      "@forgeai/ui/*": ["packages/ui/src/*"],
      "@forgeai/auth/*": ["packages/auth/src/*"],
      "@forgeai/ai/*": ["packages/ai/src/*"],
      "@forgeai/cognitive/*": ["packages/cognitive/src/*"],
      "@forgeai/email/*": ["packages/email/src/*"],
      "@forgeai/testing/*": ["packages/testing/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
